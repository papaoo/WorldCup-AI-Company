# WorldCup AI Company local environment example
# Copy to .env or set these variables in your shell. Do not commit real secrets.

LLM_PROVIDER=deepseek
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_API_KEY=replace-with-your-key

# Optional paid/limited data sources. Keep empty by default.
GNEWS_API_KEY=
THE_ODDS_API_KEY=
FOOTBALL_DATA_API_KEY=

# Disabled by default for public deployment.
# Set to 1 only on a trusted local/dev machine to enable seed, harness,
# manual workflow, bootstrap and heavy backtest endpoints.
WORLDCUP_ENABLE_DEV_ENDPOINTS=0

# Optional cost tuning
DEEPSEEK_CHAT_INPUT_USD_PER_1M=0.28
DEEPSEEK_CHAT_OUTPUT_USD_PER_1M=0.42
